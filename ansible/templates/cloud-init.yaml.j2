#cloud-config

hostname: {{ instance_name }}
fqdn: {{ instance_name }}.troshka.local

packages:
  - qemu-kvm
  - libvirt
  - libvirt-devel
  - virt-install
  - python3
  - python3-pip
  - python3-libvirt
  - dnsmasq
  - nftables
  - curl
  - git

runcmd:
  - systemctl enable --now libvirtd
  - systemctl enable --now nftables
  # Verify nested virtualization is available
  - |
    if grep -q vmx /proc/cpuinfo || grep -q svm /proc/cpuinfo; then
      echo "Nested virtualization: ENABLED" > /var/log/troshka-setup.log
    else
      echo "WARNING: Nested virtualization NOT detected" > /var/log/troshka-setup.log
    fi
  # Create troshka agent directories
  - mkdir -p /var/lib/troshka/images /var/lib/troshka/vms /etc/troshka-agent
  # Install troshka agent (placeholder - will be replaced with actual agent install)
  - echo "Troshka agent not yet installed - awaiting Phase 5 completion" >> /var/log/troshka-setup.log
  - echo "Setup complete at $(date)" >> /var/log/troshka-setup.log

write_files:
  - path: /etc/troshka-agent/config.yaml
    content: |
      api:
        url: "{{ troshka_api_url | default('https://troshka.example.com') }}"
      storage:
        image_cache_dir: /var/lib/troshka/images
        image_cache_max_gb: 200
        vm_disk_dir: /var/lib/troshka/vms
      libvirt:
        uri: "qemu:///system"
      health:
        interval_seconds: 30
    permissions: '0640'

final_message: "Troshka host setup complete after $UPTIME seconds"
